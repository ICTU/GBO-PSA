        ebw_qerds_adapter("`**QERDS-adapter<br>(integratie/client)**`")
        ebw_pub_qtsp("`**Publieke QTSP**`")
        ebw_qtsp["Private QTSP"]
        ebw_wallet["EBW<br>(publiek/privaat)"]
  end

  fsc_pap <--> fsc
