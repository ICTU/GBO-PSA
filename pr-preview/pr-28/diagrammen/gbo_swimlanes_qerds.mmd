flowchart LR
  subgraph gbo["GBO Basis"]
    direction TB
        fsc_pap("`**PAP<br>(beleidsregels)**`")
        fsc("`**FSC / GraphQL / PBAC<br>(generieke bronontsluiting)**`")
        fsc_tools("`**GBO tools<br>(vertaallaag)**`")
  end
  subgraph eudi["EUDI-Wallet"]
    direction LR
        eudi_asi("`**ASI-provider<br>(verify dienst)**`")
        eudi_pubeaa("`**PubEAA-provider<br>(PubEAA)**`")
        eudi_qeaa["QTSP<br>(QEAA)"]
        eudi_wallet["EUDI-Wallet burger"]
  end
  subgraph oots["SDG / OOTS"]
    direction LR
        oots_adapter("`**OOTS adapter<br>(semantische mapping)**`")
        oots_basis["Basisinrichting OOTS<br>RINIS / BZK"]
        oots_afnemer["Europese overheid<br>SDG-portaal"]
  end
  subgraph dvtp["DvTP"]
    direction LR
        dvtp_toestemming("`**Toestemmingsvoorziening**`")
        dvtp_pseudoniem["Pseudonimiseervoorziening<br>(BSNk PP)"]
        dvtp_afnemer["Private dienstverlener"]
  end
  subgraph ebw["QERDS"]
